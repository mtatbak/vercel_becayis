  ],
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/gizlilik", "destination": "/index.html" },
    { "source": "/privacy", "destination": "/index.html" },
    { "source": "/privacy-policy", "destination": "/index.html" },
    { "source": "/kvkk", "destination": "/kvkk.html" },
    { "source": "/kvkk-aydinlatma", "destination": "/kvkk.html" },
    { "source": "/hesap-sil", "destination": "/hesap-sil.html" },
    { "source": "/account-deletion", "destination": "/hesap-sil.html" },
    { "source": "/delete-account", "destination": "/hesap-sil.html" },
    { "source": "/hakkinda", "destination": "/hakkinda.html" },
    { "source": "/about", "destination": "/hakkinda.html" },
    { "source": "/disclaimer", "destination": "/hakkinda.html" },
    { "source": "/sorumluluk-reddi", "destination": "/hakkinda.html" }
  ]
