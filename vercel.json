{
  "version": 2,
  "name": "becayiscepte",
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "headers": [
    {
      "source": "/style.css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, must-revalidate" }
      ]
    },
    {
      "source": "/(gizlilik|privacy|kvkk|hesap-sil|account-deletion|hakkinda|about|disclaimer|sorumluluk-reddi)",
